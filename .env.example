# ─── Application ───────────────────────────────────────────────────────────────
APP_ENV=dev                              # dev | staging | production
DJANGO_SECRET_KEY=change-me-to-random-64-chars
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# ─── Database (PostgreSQL + pgvector recommended) ─────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=tkos
DB_USER=tkos
DB_PASSWORD=tkos
DB_HOST=127.0.0.1
DB_PORT=5432

# ─── Cache & Celery (Redis) ────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ─── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ─── LLM (OpenAI-compatible) ──────────────────────────────────────────────────
OPENAI_API_KEY=
LLM_BASE_URL=                            # Optional: custom endpoint (e.g. vLLM, Ollama)
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# ─── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
ENABLE_PGVECTOR=true
VECTOR_SEARCH_PROBES=10

# ─── Secret Encryption (Fernet) ───────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_MASTER_KEY=
ALLOW_PLAINTEXT_SECRETS_IN_DEV=true

# ─── Object Storage (MinIO / S3) ──────────────────────────────────────────────
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_RAW=tko-raw
S3_BUCKET_ATTACHMENTS=tko-attachments
S3_BUCKET_EXPORTS=tko-exports
S3_BUCKET_SNAPSHOTS=tko-snapshots

# ─── Context Assembly ─────────────────────────────────────────────────────────
MAX_CONTEXT_CHARS=30000

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
